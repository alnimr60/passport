rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- Users Collection ---
    match /users/{userId} {
      allow get: if isSignedIn() && (isOwner(userId) || isAdmin());
      allow list: if isAdmin();
      
      allow create: if isOwner(userId) 
                    && isValidId(userId)
                    && incoming().uid == request.auth.uid
                    && incoming().email == request.auth.token.email
                    && request.auth.token.email_verified == true
                    && (!('assignedStamps' in incoming()) || incoming().assignedStamps.size() == 0)
                    && incoming().name is string && incoming().name.size() <= 100
                    && incoming().nationality is string && incoming().nationality.size() <= 100
                    && incoming().birthDate is string && incoming().birthDate.size() <= 100
                    && incoming().address is string && incoming().address.size() <= 200
                    && incoming().faculty is string && incoming().faculty.size() <= 100
                    && incoming().year is string && incoming().year.size() <= 100
                    && (incoming().photoUrl == null || (incoming().photoUrl is string && incoming().photoUrl.size() <= 2000000));

      allow update: if (isOwner(userId) && (
                        incoming().diff(existing()).affectedKeys().hasOnly(['name', 'nationality', 'birthDate', 'address', 'faculty', 'year', 'photoUrl', 'updatedAt'])
                        && incoming().name is string && incoming().name.size() <= 100
                        && incoming().nationality is string && incoming().nationality.size() <= 100
                        && (incoming().photoUrl == null || (incoming().photoUrl is string && incoming().photoUrl.size() <= 2000000))
                      )) || (isAdmin() && (
                        incoming().diff(existing()).affectedKeys().hasOnly(['assignedStamps', 'updatedAt'])
                        && incoming().assignedStamps is list
                      ));
    }

    // --- Stamps Collection ---
    match /stamps/{stampId} {
      allow read: if isSignedIn();
      allow write: if isAdmin() && isValidId(stampId);
    }

    // --- Admins Collection ---
    match /admins/{adminId} {
      allow read: if isSignedIn() && isOwner(adminId);
      // Allow the developer to bootstrap themselves as admin
      allow create: if isSignedIn() && isOwner(adminId) && request.auth.token.email == 'alnimr60@gmail.com';
      allow update, delete: if false;
    }
  }
}
